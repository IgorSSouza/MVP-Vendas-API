{
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=data/sales.db"
  },
  "Jwt": {
    "Issuer": "Sales.Api",
    "Audience": "Sales.Frontend",
    "SecretKey": "CHANGE_THIS_TO_A_LONG_RANDOM_KEY_WITH_AT_LEAST_32_CHARS",
    "ExpiresInMinutes": 60
  },
  "GoogleAuth": {
    "AllowedAudiences": [
      "YOUR_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
    ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
